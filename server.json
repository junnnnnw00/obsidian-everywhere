{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.junnnnnw00/obsidian-everywhere",
  "title": "Obsidian Everywhere",
  "description": "Graph-native MCP server for reading, navigating, and safely editing Obsidian vaults.",
  "version": "0.3.3",
  "repository": {
    "url": "https://github.com/junnnnnw00/obsidian-everywhere",
    "source": "github",
    "id": "1301842269"
  },
  "websiteUrl": "https://github.com/junnnnnw00/obsidian-everywhere",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/junnnnnw00/obsidian-everywhere/main/assets/icon.png",
      "mimeType": "image/png",
      "sizes": ["512x512"]
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "obsidian-everywhere",
      "version": "0.3.3",
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        }
      ],
      "packageArguments": [
        {
          "type": "positional",
          "valueHint": "vault_path",
          "description": "Absolute path to the Obsidian vault",
          "format": "filepath",
          "isRequired": true
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
