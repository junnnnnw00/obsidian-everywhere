{
  "name": "obsidian-everywhere",
  "version": "0.3.1",
  "description": "Graph-native MCP server for searching, navigating, and safely editing Obsidian vaults from any MCP client.",
  "mcpName": "io.github.junnnnnw00/obsidian-everywhere",
  "license": "MIT",
  "type": "module",
  "author": "junnnnnw00",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/junnnnnw00/obsidian-everywhere.git"
  },
  "homepage": "https://github.com/junnnnnw00/obsidian-everywhere#readme",
  "bugs": {
    "url": "https://github.com/junnnnnw00/obsidian-everywhere/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "obsidian",
    "claude",
    "codex",
    "chatgpt",
    "knowledge-graph",
    "pkm",
    "obsidian-mcp",
    "mcp-server"
  ],
  "bin": {
    "obsidian-everywhere": "dist/cli.js",
    "obsidian-everywhere-http": "dist/http-cli.js",
    "obsidian-everywhere-oauth-http": "dist/oauth-http-cli.js"
  },
  "engines": {
    "node": "20.x || 22.x || 23.x || 24.x || 25.x || 26.x"
  },
  "files": [
    "dist",
    "assets/social-preview.jpg",
    "assets/demo.gif"
  ],
  "scripts": {
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev:stdio": "tsx src/cli.ts",
    "dev:http": "tsx src/http-cli.ts",
    "dev:oauth-http": "tsx src/oauth-http-cli.ts",
    "demo": "tsx src/cli.ts demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "product-hunt:prepare": "node scripts/prepare-product-hunt.mjs",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "express": "^5.2.1",
    "graphology": "^0.26.0",
    "graphology-metrics": "^2.3.1",
    "graphology-shortest-path": "^2.1.0",
    "gray-matter": "^4.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.5",
    "eslint": "^10.7.0",
    "gpt-tokenizer": "^3.4.0",
    "prettier": "3.9.5",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.0.7"
  }
}
