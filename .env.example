# Copy to .env and fill in. Never commit the real .env file.

# Absolute path to your Obsidian vault on the host machine.
OBSIDIAN_VAULT_HOST_PATH=/absolute/path/to/your/vault

# Static bearer token for the remote-Claude-Code service (Tailscale-only).
# Generate one with: openssl rand -hex 32
OBSIDIAN_EVERYWHERE_TOKEN=

# --- claude.ai connector (OAuth) service — only needed if you use it ---

# Public HTTPS origin this server is reachable at, e.g. your Cloudflare
# Tunnel hostname: https://obsidian.example.com
OAUTH_ISSUER_URL=

# Single-user login secret entered on the connector's sign-in page.
# Generate one with: openssl rand -hex 32
OAUTH_LOGIN_SECRET=
